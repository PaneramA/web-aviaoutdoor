---
const navItems = [
  { href: "#solutions", label: "Solutions" },
  { href: "#equipment-brands", label: "Equipment" },
  { href: "#how-it-works", label: "Flow Event" },
  { href: "#scroll-frame-gallery", label: "Gallery" },
  { href: "#contact", label: "Contact" },
];

const whatsappUrl = "https://wa.me/6287861488788";
---

<header class="pointer-events-none fixed inset-x-0 top-3 z-50 px-4 sm:top-5 sm:px-6">
  <nav
    aria-label="Primary"
    class="pointer-events-auto relative mx-auto flex h-[64px] w-full max-w-[1280px] items-center rounded-[16px] border border-[rgba(0,0,0,0.08)] bg-white px-4 shadow-[0_18px_50px_rgba(0,0,0,0.10)] sm:h-[74px] sm:rounded-[18px] sm:px-6 lg:px-8"
  >
    <div class="flex min-w-0 flex-1 items-center lg:basis-[210px] lg:flex-none">
      <a
        href="#home"
        class="font-heading text-[22px] leading-none font-black uppercase tracking-[0] text-avia-black transition-colors duration-200 hover:text-avia-orange focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-avia-orange/40 sm:text-[26px]"
      >
        AVIA OUTDOOR
      </a>
    </div>

    <div class="hidden flex-1 items-center justify-center lg:flex">
      <ul class="flex items-center gap-8" role="list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-[15px] font-semibold text-avia-black transition-colors duration-200 hover:text-avia-orange focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-avia-orange/40 xl:text-[16px]"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="flex flex-1 items-center justify-end lg:basis-[220px] lg:flex-none">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="whatsapp-cta hidden h-[52px] w-full max-w-[218px] items-center rounded-[16px] text-[14px] font-extrabold lg:inline-flex"
      >
        <span class="whatsapp-cta__icon" aria-hidden="true">
          <svg viewBox="-0.6 -0.6 17.2 17.2">
            <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93a7.898 7.898 0 0 0-2.327-5.607ZM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592Zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.066-.315-.099-.445.099-.133.197-.514.646-.627.775-.116.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.101-1.372-.116-.198-.013-.305.086-.404.09-.09.197-.232.296-.348.1-.116.133-.198.198-.33.066-.133.033-.25-.017-.348-.05-.099-.445-1.075-.612-1.47-.161-.389-.323-.336-.445-.342-.116-.007-.25-.007-.38-.007a.729.729 0 0 0-.529.25c-.182.198-.695.679-.695 1.653s.712 1.916.81 2.049c.099.133 1.397 2.132 3.386 2.992.473.205.842.328 1.129.421.475.151.906.129 1.248.078.38-.058 1.171-.48 1.336-.943.165-.464.165-.86.116-.943-.05-.082-.182-.132-.38-.23Z"></path>
          </svg>
        </span>
        <span class="whatsapp-cta__label">Diskusikan Event</span>
      </a>

      <button
        data-mobile-menu-toggle
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        class="inline-flex h-11 items-center justify-center rounded-[14px] border border-black/10 px-4 text-[14px] font-semibold text-avia-black transition-colors duration-200 hover:border-avia-orange hover:text-avia-orange focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-avia-orange/40 sm:h-12 sm:rounded-[16px] sm:px-5 sm:text-[15px] lg:hidden"
      >
        Menu
      </button>
    </div>

    <div
      id="mobile-navigation"
      data-mobile-menu
      class="absolute left-0 right-0 top-[calc(100%+0.6rem)] hidden rounded-[16px] border border-black/8 bg-white p-3 shadow-[0_18px_42px_rgba(0,0,0,0.12)] lg:hidden"
    >
      <ul class="grid gap-1" role="list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="block rounded-[12px] px-4 py-3 text-[15px] font-semibold text-avia-black transition-colors duration-200 hover:bg-avia-orange/10 hover:text-avia-orange focus-visible:bg-avia-orange/10 focus-visible:text-avia-orange focus-visible:outline-none"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="whatsapp-cta mt-2 flex h-[52px] w-full items-center rounded-[14px] text-[14px] font-extrabold"
      >
        <span class="whatsapp-cta__icon" aria-hidden="true">
          <svg viewBox="-0.6 -0.6 17.2 17.2">
            <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93a7.898 7.898 0 0 0-2.327-5.607ZM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592Zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.066-.315-.099-.445.099-.133.197-.514.646-.627.775-.116.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.101-1.372-.116-.198-.013-.305.086-.404.09-.09.197-.232.296-.348.1-.116.133-.198.198-.33.066-.133.033-.25-.017-.348-.05-.099-.445-1.075-.612-1.47-.161-.389-.323-.336-.445-.342-.116-.007-.25-.007-.38-.007a.729.729 0 0 0-.529.25c-.182.198-.695.679-.695 1.653s.712 1.916.81 2.049c.099.133 1.397 2.132 3.386 2.992.473.205.842.328 1.129.421.475.151.906.129 1.248.078.38-.058 1.171-.48 1.336-.943.165-.464.165-.86.116-.943-.05-.082-.182-.132-.38-.23Z"></path>
          </svg>
        </span>
        <span class="whatsapp-cta__label">Diskusikan Event</span>
      </a>
    </div>
  </nav>
</header>

<style>
  .whatsapp-cta {
    justify-content: center;
    gap: 0.5rem;
    border: 0;
    background: #05ca12;
    box-shadow: none;
    color: #fff;
    padding: 0 0.9rem;
    transition: background-color 180ms ease;
  }

  .whatsapp-cta:hover {
    background: #05b911;
  }

  .whatsapp-cta:focus-visible {
    outline: 3px solid rgba(5, 202, 18, 0.38);
    outline-offset: 2px;
  }

  .whatsapp-cta__icon {
    display: inline-flex;
    height: 2rem;
    width: 2rem;
    align-items: center;
    justify-content: center;
    color: #fff;
  }

  .whatsapp-cta__icon svg {
    display: block;
    height: 1.9rem;
    width: 1.9rem;
    fill: currentColor;
  }

  .whatsapp-cta__label {
    min-width: 0;
    line-height: 1;
    text-align: center;
    transform: translateY(-1px);
    white-space: nowrap;
  }
</style>

<script>
  const menuToggle = document.querySelector<HTMLButtonElement>("[data-mobile-menu-toggle]");
  const mobileMenu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  if (menuToggle && mobileMenu) {
    const closeMenu = () => {
      mobileMenu.classList.add("hidden");
      menuToggle.setAttribute("aria-expanded", "false");
    };

    menuToggle.addEventListener("click", () => {
      const isOpen = menuToggle.getAttribute("aria-expanded") === "true";

      mobileMenu.classList.toggle("hidden", isOpen);
      menuToggle.setAttribute("aria-expanded", String(!isOpen));
    });

    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });
  }
</script>
