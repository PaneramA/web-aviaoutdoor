---
const navItems = [
  { href: "#solutions", label: "Solutions" },
  { href: "#equipment-brands", label: "Equipment" },
  { href: "#how-it-works", label: "Flow Event" },
  { href: "#scroll-frame-gallery", label: "Gallery" },
  { href: "#contact", label: "Contact" },
];
---

<header class="pointer-events-none fixed inset-x-0 top-5 z-50 px-6">
  <nav
    aria-label="Primary"
    class="pointer-events-auto mx-auto flex h-[74px] w-full max-w-[1280px] items-center rounded-[18px] border border-[rgba(0,0,0,0.08)] bg-white px-5 shadow-[0_18px_50px_rgba(0,0,0,0.10)] sm:px-6 lg:px-8"
  >
    <div class="flex min-w-0 flex-1 items-center lg:basis-[210px] lg:flex-none">
      <a
        href="#home"
        class="font-heading text-[24px] leading-none font-black uppercase tracking-[-0.035em] text-avia-black transition-colors duration-200 hover:text-avia-orange focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-avia-orange/40 sm:text-[26px]"
      >
        AVIA OUTDOOR
      </a>
    </div>

    <div class="hidden flex-1 items-center justify-center lg:flex">
      <ul class="flex items-center gap-8" role="list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-[15px] font-semibold text-avia-black transition-colors duration-200 hover:text-avia-orange focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-avia-orange/40 xl:text-[16px]"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="flex flex-1 items-center justify-end lg:basis-[220px] lg:flex-none">
      <a
        href="#contact"
        class="hidden h-[52px] items-center justify-center rounded-[16px] bg-avia-orange px-7 text-[14px] font-extrabold text-avia-black shadow-[0_12px_28px_rgba(255,142,36,0.24)] transition duration-200 hover:-translate-y-0.5 hover:bg-[#f47f12] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-avia-orange/50 lg:inline-flex"
      >
        Diskusikan Event
      </a>

      <button
        type="button"
        aria-label="Open navigation menu"
        class="inline-flex h-12 items-center justify-center rounded-[16px] border border-black/10 px-5 text-[15px] font-semibold text-avia-black transition-colors duration-200 hover:border-avia-orange hover:text-avia-orange focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-avia-orange/40 lg:hidden"
      >
        Menu
      </button>
    </div>
  </nav>
</header>
