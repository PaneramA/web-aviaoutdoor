---
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";

const publicImagesDir = fileURLToPath(new URL("../../public/images", import.meta.url));

const cards = [
  {
    title: "Camping",
    imagePath: "/images/card-camping-ceria.webp",
    fileName: "card-camping-ceria.webp",
    objectPosition: "50% 58%",
    placeholder: "from-[#f2ede5] via-[#ddd5ca] to-[#bbb09e]",
  },
  {
    title: "Hiking",
    imagePath: "/images/card-hiking.webp",
    fileName: "card-hiking.webp",
    objectPosition: "50% 50%",
    placeholder: "from-[#f7ede2] via-[#efe0cf] to-[#d8c4ad]",
  },
  {
    title: "Outbound",
    imagePath: "/images/card-outbound.webp",
    fileName: "card-outbound.webp",
    objectPosition: "54% 50%",
    placeholder: "from-[#ece6dc] via-[#d8d0c3] to-[#b6ab99]",
  },
].map((card) => ({
  ...card,
  hasImage: fs.existsSync(path.join(publicImagesDir, card.fileName)),
}));
---

<section
  id="solutions"
  class="next-panel relative z-20 scroll-mt-28 rounded-t-[24px] bg-white px-5 pt-14 shadow-[0_-14px_36px_rgba(4,4,4,0.05)] sm:scroll-mt-32 sm:rounded-t-[32px] sm:px-8 sm:pt-20 lg:min-h-[100svh] lg:px-10 lg:pt-28 xl:pt-32"
>
  <div class="mx-auto max-w-[1280px] pb-16 sm:pb-20 lg:pb-24">
    <div class="mx-auto max-w-[1040px] text-center">
      <h2 class="solutions-title font-heading font-black uppercase text-avia-black">
        <span class="block text-avia-orange">Temukan Solusi</span>
        <span class="block text-avia-black">Yang Tepat Untuk Anda</span>
      </h2>
    </div>

    <div class="mx-auto mt-10 grid max-w-[1240px] gap-5 sm:mt-12 sm:gap-7 md:mt-16 md:grid-cols-2 lg:mt-20 xl:grid-cols-3 xl:gap-8">
      {
        cards.map((card, index) => (
          <article class="group h-full">
            <div class="h-[340px] overflow-hidden rounded-[22px] bg-white shadow-[0_18px_36px_rgba(4,4,4,0.08)] ring-1 ring-black/6 transition duration-[260ms] ease-out will-change-transform group-hover:scale-[0.98] sm:h-[480px] sm:rounded-[32px] md:h-[530px] xl:h-[600px]">
              <div class="relative h-full overflow-hidden">
                {
                  card.hasImage ? (
                    <img
                      src={card.imagePath}
                      alt={card.title}
                      class="h-full w-full object-cover"
                      style={`object-position: ${card.objectPosition};`}
                      loading="eager"
                      decoding="async"
                      fetchpriority={index === 0 ? "high" : "auto"}
                    />
                  ) : (
                    <div
                      class:list={[
                        "h-full w-full bg-gradient-to-br",
                        card.placeholder,
                      ]}
                    ></div>
                  )
                }

                <div class="solutions-card__title-strip absolute inset-x-0 top-0 translate-y-[-10px] bg-[linear-gradient(180deg,rgba(0,0,0,0.66)_0%,rgba(0,0,0,0.46)_46%,rgba(0,0,0,0.16)_78%,rgba(0,0,0,0)_100%)] px-5 pb-14 pt-6 opacity-0 transition duration-[280ms] ease-out group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:translate-y-0 group-focus-within:opacity-100 sm:px-8 sm:pb-20 sm:pt-8 lg:px-[34px] lg:pb-24">
                  <h3 class="max-w-[240px] text-[28px] leading-[0.96] font-black tracking-[0] text-white drop-shadow-[0_4px_14px_rgba(0,0,0,0.34)] sm:text-[32px] lg:text-[34px]">
                    {card.title}
                  </h3>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .solutions-title {
    font-size: 2.875rem;
    line-height: 0.94;
    letter-spacing: 0;
  }

  @media (min-width: 640px) {
    .solutions-title {
      font-size: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .solutions-title {
      font-size: 5.25rem;
      line-height: 0.92;
    }
  }

  @media (hover: none) {
    .solutions-card__title-strip {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
