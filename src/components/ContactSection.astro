---
const mapsUrl = "https://maps.app.goo.gl/Mdm29S5L1sf4Rc239";
const instagramUrl = "https://www.instagram.com/avia_outdoor/";
const whatsappUrl = "https://wa.me/6287861488788";
const emailAddress = "aviaoutdoor2022@gmail.com";

const footerLinks = [
  { href: "#solutions", label: "Solutions" },
  { href: "#equipment-brands", label: "Equipment" },
  { href: "#how-it-works", label: "Flow Event" },
  { href: "#scroll-frame-gallery", label: "Gallery" },
  { href: mapsUrl, label: "Google Maps", external: true },
];
---

<footer id="contact" class="footer-contact bg-avia-black px-5 text-white sm:px-8 lg:px-10">
  <div class="mx-auto w-full max-w-[1280px] py-10 sm:py-12">
    <div class="flex flex-col gap-7 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <a href="#home" class="footer-contact__brand font-heading font-black uppercase text-white">
          AVIA OUTDOOR
        </a>

        <nav class="mt-7" aria-label="Footer navigation">
          <ul class="flex flex-wrap gap-x-7 gap-y-3 text-sm font-semibold text-white/48" role="list">
            {
              footerLinks.map((item) => (
                <li>
                  <a
                    class="footer-contact__link"
                    href={item.href}
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noreferrer" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <div class="footer-contact__social-list sm:justify-end">
        <a
          class="footer-contact__social footer-contact__social--instagram"
          href={instagramUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram Avia Outdoor"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="5" y="5" width="14" height="14" rx="4"></rect>
            <circle cx="12" cy="12" r="3.2"></circle>
            <path d="M16.6 7.6h.01"></path>
          </svg>
        </a>
        <a
          class="footer-contact__social footer-contact__social--whatsapp"
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="WhatsApp Avia Outdoor"
        >
          <svg viewBox="-0.6 -0.6 17.2 17.2" aria-hidden="true">
            <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93a7.898 7.898 0 0 0-2.327-5.607ZM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592Zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.066-.315-.099-.445.099-.133.197-.514.646-.627.775-.116.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.101-1.372-.116-.198-.013-.305.086-.404.09-.09.197-.232.296-.348.1-.116.133-.198.198-.33.066-.133.033-.25-.017-.348-.05-.099-.445-1.075-.612-1.47-.161-.389-.323-.336-.445-.342-.116-.007-.25-.007-.38-.007a.729.729 0 0 0-.529.25c-.182.198-.695.679-.695 1.653s.712 1.916.81 2.049c.099.133 1.397 2.132 3.386 2.992.473.205.842.328 1.129.421.475.151.906.129 1.248.078.38-.058 1.171-.48 1.336-.943.165-.464.165-.86.116-.943-.05-.082-.182-.132-.38-.23Z"></path>
          </svg>
        </a>
        <a
          class="footer-contact__social footer-contact__social--gmail"
          href={`mailto:${emailAddress}`}
          aria-label={`Kirim email ke ${emailAddress}`}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path class="gmail-blue" d="M2.5 5.65v11.8c0 .86.72 1.55 1.6 1.55h3V9.1L2.5 5.65Z"></path>
            <path class="gmail-green" d="M16.9 9.1V19h3c.88 0 1.6-.69 1.6-1.55V5.65L16.9 9.1Z"></path>
            <path class="gmail-yellow" d="m16.9 9.1 4.6-3.45V4.9c0-1.92-2.22-3.02-3.78-1.87l-.82.61V9.1Z"></path>
            <path class="gmail-red" d="M7.1 9.1V3.64L12 7.32l4.9-3.68V9.1L12 12.78 7.1 9.1Z"></path>
            <path class="gmail-red-dark" d="M2.5 5.65 7.1 9.1V3.64l-.82-.61C4.72 1.88 2.5 2.98 2.5 4.9v.75Z"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-8 border-t border-white/10 pt-7 text-sm text-white/38">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-wrap gap-x-8 gap-y-3">
          <a class="footer-contact__link" href="#contact">Privacy Policy</a>
          <a class="footer-contact__link" href="#contact">Event Brief Notice</a>
        </div>
        <p>© 2026 Avia Outdoor. All Rights Reserved.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-contact {
    position: relative;
    isolation: isolate;
  }

  .footer-contact::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(circle at 82% 0%, rgba(255, 142, 36, 0.04), transparent 18rem);
    pointer-events: none;
  }

  .footer-contact__brand {
    display: inline-block;
    font-size: 2rem;
    line-height: 0.9;
    letter-spacing: 0;
  }

  .footer-contact__link {
    color: inherit;
    transition: color 200ms ease;
  }

  .footer-contact__link:hover,
  .footer-contact__link:focus-visible {
    color: rgba(255, 255, 255, 0.92);
    outline: none;
  }

  .footer-contact__social-list {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-contact__social {
    display: inline-flex;
    box-sizing: border-box;
    flex: 0 0 2.15rem;
    height: 2.15rem;
    width: 2.15rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: #fff;
    transition:
      box-shadow 200ms ease,
      transform 200ms ease;
  }

  .footer-contact__social:hover,
  .footer-contact__social:focus-visible {
    box-shadow: 0 12px 24px rgba(255, 142, 36, 0.12);
    outline: none;
    transform: translateY(-0.12rem);
  }

  .footer-contact__social svg {
    display: block;
    flex: none;
    height: 1.28rem;
    overflow: visible;
    width: 1.28rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .footer-contact__social--instagram {
    background:
      radial-gradient(circle at 31% 108%, #fdf497 0 24%, #fd5949 43%, #d6249f 62%, #285aeb 100%);
  }

  .footer-contact__social--instagram svg {
    stroke: #fff;
    stroke-width: 2.1;
  }

  .footer-contact__social--whatsapp {
    background: #25d366;
  }

  .footer-contact__social--whatsapp svg {
    fill: #fff;
    stroke: none;
    transform: none;
  }

  .footer-contact__social--gmail {
    background: #fff;
  }

  .footer-contact__social--gmail svg {
    height: 1.42rem;
    width: 1.42rem;
    fill: none;
    stroke: none;
  }

  .footer-contact__social--gmail .gmail-blue {
    fill: #4285f4;
  }

  .footer-contact__social--gmail .gmail-green {
    fill: #34a853;
  }

  .footer-contact__social--gmail .gmail-yellow {
    fill: #fbbc04;
  }

  .footer-contact__social--gmail .gmail-red {
    fill: #ea4335;
  }

  .footer-contact__social--gmail .gmail-red-dark {
    fill: #c5221f;
  }

  @media (min-width: 640px) {
    .footer-contact__brand {
      font-size: 2.35rem;
    }
  }
</style>
